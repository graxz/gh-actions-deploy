{
  "name": "gh-actions-deploy",
  "version": "1.0.0",
  "description": "Projeto com pipeline CI/CD completa usando GitHub Actions",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
