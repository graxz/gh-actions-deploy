    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
